# SerbiaTracker - Variables d'environnement
# Copier ce fichier en .env et renseigner les cles

# Unwired Labs - Geolocalisation par antennes (le plus important)
# Inscription gratuite: https://unwiredlabs.com/
UNWIRED_LABS_TOKEN=

# Google Geolocation API (fallback)
GOOGLE_GEOLOCATION_API_KEY=

# Numverify - Lookup numero + operateur
# Inscription gratuite: https://numverify.com/
NUMVERIFY_API_KEY=

# Twilio Lookup v2
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Infobip - HLR Lookup (GRATUIT pour test, base en Serbie)
# Excellente couverture Serbie car Infobip est une entreprise serbe
# Inscription: https://www.infobip.com/signup
INFOBIP_API_KEY=

# OpenCellID
OPENCELLID_API_KEY=
